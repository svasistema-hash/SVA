# Backend env vars — copiar a .env y completar.
#
# Generar JWT_SECRET (64 bytes hex):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Generar ENCRYPTION_KEY (32 bytes hex = 256 bits para AES-256):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Puerto del servidor (Railway inyecta PORT automáticamente).
PORT=3002

NODE_ENV=development

# CRÍTICOS — generar nuevos para producción, NUNCA commitear.
# Cambiar ENCRYPTION_KEY rompe TODOS los datos encriptados existentes.
JWT_SECRET=replace_with_64_byte_hex
ENCRYPTION_KEY=replace_with_32_byte_hex

# Paths en disco.
# En Railway con volumen persistente montado en /data:
#   DB_PATH=/data/lexdocs.db
#   UPLOADS_PATH=/data/uploads
#   PDFS_PATH=/data/pdfs
DB_PATH=./lexdocs.db
UPLOADS_PATH=../uploads
PDFS_PATH=../pdfs

# CORS — en producción apuntar al dominio Vercel del frontend.
# CORS_ORIGIN=https://tu-app.vercel.app
