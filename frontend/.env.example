# Frontend env vars (Vite lee solo VITE_* prefixed)
#
# DEV local (default):
#   VITE_API_URL=/api
#   El proxy de Vite (vite.config.js) reenvía /api -> http://localhost:3002.
#
# PRODUCCIÓN en Vercel:
#   Configurar en Vercel Dashboard > Settings > Environment Variables:
#   VITE_API_URL=https://<tu-app>.up.railway.app/api
#   (sin proxy, llamadas directas al dominio del backend)

VITE_API_URL=/api
